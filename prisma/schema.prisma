generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id        String   @id @default(uuid())
  username  String   
  email     String   @unique
  password  String
}

model Projects {
  id Int @id @default(autoincrement())
  name String
  description String
  dueDate DateTime
  completed Boolean @default(false)
}

model Tasks {
  id Int @id @default(autoincrement())
  name String
  completed Boolean @default(false)
}